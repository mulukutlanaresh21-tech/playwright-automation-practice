  "item": [
    {
      "name": "Creates a duplicate repository for the authenticated user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 422\", function () {\r",
              "    pm.response.to.have.status(422);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the reposnse time of duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response body contains error message\", function () {\r",
              "    pm.expect(pm.response.json().message).to.eql(\"Repository creation failed.\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response body contains error details\", function () {\r",
              "    pm.expect(pm.response.json().errors[0].message).to.eql(\"name already exists on this account\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response status is 422\", function () {\r",
              "    pm.expect(pm.response.json().status).to.eql(\"422\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response body contains error --> resource is Repository\", function () {\r",
              "    pm.expect(pm.response.json().errors[0].resource).to.eql(\"Repository\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate schema of duplicate repository request response body\", function () {\r",
              "    pm.expect(typeof pm.response.json().message).to.eql(\"string\");\r",
              "    pm.expect(Array.isArray(pm.response.json().errors)).to.eql(true);\r",
              "    pm.expect(typeof pm.response.json().errors[0].resource).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().errors[0].code).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().errors[0].field).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().errors[0].message).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().documentation_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().status).to.eql(\"string\");\r",
              "});\r",
              "\r",
              "//wait for 2 seconds before sending the next request\r",
              "setTimeout(() =>{\r",
              "    console.log(\"Waiting for 2 seconds\");\r",
              "},2000);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Set the repository name as a global variable to access later\r",
              "pm.globals.set(\"repoName\", \"JMeterRepo\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{bearerToken}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2026-03-10",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{repoName}}\",\r\n    \"description\": \"Sample duplicate Repo from Postman\",\r\n    \"private\": false\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/user/repos",
          "host": [
