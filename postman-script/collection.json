    {
      "name": "Creates a valid repository for the authenticated user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the reposnse time of Valid repository request\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response body contains the correct repository name\", function () {\r",
              "    pm.expect(pm.response.json().name).to.eql(\"Playwright-Repo\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response body contains the correct owner\", function () {\r",
              "    pm.expect(pm.response.json().owner.login).to.eql(\"naresh212nani\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Status of valid repo creation request\", function () {\r",
              "    pm.expect(pm.response.status).to.eql(\"Created\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate repository visibility\", function () {\r",
              "    pm.expect(pm.response.json().visibility).to.eql(\"private\");\r",
              "    pm.expect(pm.response.json().private).to.eql(true);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Validate schema of Valid repository request\", function () {\r",
              "    pm.expect(typeof pm.response.json().id).to.eql(\"number\");\r",
              "    pm.expect(typeof pm.response.json().node_id).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().name).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().full_name).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().private).to.eql(\"boolean\");\r",
              "    pm.expect(typeof pm.response.json().owner).to.eql(\"object\");\r",
              "    pm.expect(typeof pm.response.json().owner.login).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().owner.id).to.eql(\"number\");\r",
              "    pm.expect(typeof pm.response.json().html_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().description).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().fork).to.eql(\"boolean\");\r",
              "    pm.expect(typeof pm.response.json().url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().forks_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().git_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().ssh_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().clone_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().svn_url).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().visibility).to.eql(\"string\");\r",
              "    pm.expect(typeof pm.response.json().has_issues).to.eql(\"boolean\");\r",
              "    pm.expect(typeof pm.response.json().permissions).to.eql(\"object\");\r",
              "});\r",
              "\r",
              "//wait for 2 seconds before sending the next request\r",
              "setTimeout(() =>{\r",
              "    console.log(\"Waiting for 2 seconds\");\r",
              "},2000);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
